  create  table "airwolf"."marts"."mart_joined__dbt_tmp"
  
  
    as
  
  (
    

with aq_area as (
    select
        area,
        obs_time,
        avg("SO2") as "SO2",
        avg("O3") as "O3",
        avg("NO2") as "NO2",
        avg("PM10") as "PM10",
        avg("PM25") as "PM25"
    from "airwolf"."marts"."mart_aq"
